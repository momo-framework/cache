includes:
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-phpunit/rules.neon

parameters:
    level: 10
    paths:
        - src
        - tests

    # UNVERIFIED ext adapters: require ext-redis / ext-memcached, absent here.
    # Verified via CI integration jobs; store logic is covered through fakes.
    excludePaths:
        - src/Store/PhpRedisClient.php
        - src/Store/PhpMemcachedClient.php
        - src/Store/StoreFactory.php

    checkExplicitMixed: true
    checkFunctionNameCase: true
    reportUnmatchedIgnoredErrors: true
    checkUninitializedProperties: true
    checkDynamicProperties: true
    checkImplicitMixed: true
    checkBenevolentUnionTypes: true

    treatPhpDocTypesAsCertain: false

    bootstrapFiles:
        - vendor/autoload.php
